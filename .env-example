# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — secrets must never be committed (guidelines §7.4).

# LLM provider API key (Anthropic). Read at runtime via os.environ only.
ANTHROPIC_API_KEY=sk-dummy-replace-me

# Optional secondary provider key (see PLAN ADR-3).
OPENAI_API_KEY=sk-dummy-replace-me
