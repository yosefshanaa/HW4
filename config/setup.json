{
  "version": "1.00",
  "paths": {
    "workspace": "workspace",
    "results": "results",
    "vault": "vault",
    "data": "data"
  },
  "models": {
    "cheap": "claude-haiku-4-5-20251001",
    "strong": "claude-sonnet-4-6"
  },
  "llm": {
    "max_output_tokens": 4096,
    "api_key_env": "ANTHROPIC_API_KEY"
  },
  "pricing_per_mtok": {
    "claude-haiku-4-5-20251001": {
      "input": 1.0,
      "output": 5.0
    },
    "claude-sonnet-4-6": {
      "input": 3.0,
      "output": 15.0
    }
  },
  "retrieval": {
    "k_pages": 3,
    "ego_radius": 2,
    "max_nodes": 40,
    "context_token_cap": 12000,
    "max_seeds": 3
  },
  "loop": {
    "max_iterations": 3,
    "metric_improvement_threshold": 0.1,
    "step_timeout_seconds": 300
  },
  "experiment": {
    "n_questions_min": 10,
    "repetitions": 2,
    "temperature": 0.0,
    "naive_context_token_cap": 16000,
    "shuffle_seed": 42,
    "model_tier": "strong",
    "assumed_output_tokens": 400
  },
  "budget": {
    "max_usd": 10.0,
    "warn_usd": 7.0
  },
  "repo": {
    "timeout_seconds": 300,
    "default_dirname": "target"
  },
  "graph": {
    "exclude_dirs": [
      ".git",
      "__pycache__",
      ".venv",
      "venv",
      "build",
      "dist",
      "examples",
      "artwork",
      "requirements",
      ".github",
      "node_modules"
    ],
    "doc_suffixes": [
      ".md",
      ".rst"
    ],
    "max_mentions_per_doc": 50,
    "code_exclude_dirs": [
      "docs"
    ]
  },
  "metrics": {
    "relations": [
      "imports",
      "calls"
    ],
    "top_k_bottlenecks": 10
  },
  "vault": {
    "project": "click-analysis",
    "domains": [
      "python",
      "cli-frameworks"
    ],
    "top_hub_pages": 5,
    "wiki_page_max_lines": 40,
    "index_max_entries_per_section": 8,
    "min_community_size": 3
  },
  "detectors": {
    "spof": {
      "min_mandatory_ratio": 0.3,
      "max_rank": 5
    },
    "god_node": {
      "degree_multiplier": 2.0,
      "min_fan_out": 3,
      "min_communities": 2,
      "percentile": 0.98
    },
    "isolation": {
      "min_size": 1
    },
    "traceability": {
      "report_undocumented": false
    },
    "duplication": {
      "min_confidence": 0.5
    }
  },
  "fixloop": {
    "branch_prefix": "fix/",
    "max_edit_retries": 1,
    "test_command": [
      "uv",
      "run",
      "--no-project",
      "--with-editable",
      ".",
      "--with",
      "pytest",
      "pytest",
      "-q",
      "tests"
    ]
  }
}
